{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@design-editor/canvas-engine": ["packages/canvas-engine/src/index.ts"],
      "@design-editor/common-types": ["packages/common-types/src/index.ts"],
      "@design-editor/design-schema": ["packages/design-schema/generated/index.ts"],
      "@design-editor/ui": ["packages/ui/src/index.ts"]
    }
  }
}
